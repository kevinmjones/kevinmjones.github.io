<button class="theme-toggle" type="button" aria-label="Toggle theme" data-theme-toggle>
  <span data-theme-icon-light>☀</span>
  <span data-theme-icon-dark hidden>☾</span>
</button>

<script>
  function syncIcons(theme: string) {
    const light = document.querySelector<HTMLElement>('[data-theme-icon-light]');
    const dark = document.querySelector<HTMLElement>('[data-theme-icon-dark]');
    if (!light || !dark) return;
    light.hidden = theme === 'dark';
    dark.hidden = theme !== 'dark';
  }

  function init() {
    const btn = document.querySelector<HTMLButtonElement>('[data-theme-toggle]');
    if (!btn) return;
    syncIcons(document.documentElement.dataset.theme || 'light');
    btn.addEventListener('click', () => {
      const current = document.documentElement.dataset.theme || 'light';
      const next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.dataset.theme = next;
      localStorage.setItem('theme', next);
      syncIcons(next);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
