    eyebrow: 'kevinmjones / field note / klax26',
    heroTitle: 'Building KLAX26: a leakage-safe <em>weather market</em> system',
    kicker: 'A research system for one recurring Kalshi contract, built from the settlement source backward.',
    status: 'paper only',
    statusTone: 'green',
    metrics: [
      { label: 'settlement source', value: 'CLI LAX', sub: 'NWS Daily Climate Report', tone: 'amb' },
      { label: 'label audit', value: '260/261', sub: '99.6% vs populated Kalshi field', tone: 'green' },
      { label: 'prod brier', value: '0.7286', sub: 'Iso(Residual(Climatology))', tone: 'teal' },
      { label: 'boundary floor', value: '1.5°F', sub: 'M1 refuse/downsize zone', tone: 'amb' },
    ],
    nodes: [
      { label: 'source truth', value: 'NWS CLI LAX' },
      { label: 'data lake', value: 'provenance + available_at' },
      { label: 'model', value: 'calibrated PMF' },
      { label: 'risk', value: 'M1 boundary buffer' },
      { label: 'mode', value: 'paper-only path' },
    ],
