      { label: 'ipc actions', value: '70+', sub: 'auth, agents, data, voice, vault', tone: 'teal' },
      { label: 'packaging', value: 'DMG', sub: 'macOS build path configured', tone: 'rose' },
      { label: 'review', value: 'PASS', sub: 'sensitive values excluded', tone: 'green' },
    ],
    nodes: [
      { label: 'renderer', value: 'React workspace' },
      { label: 'bridge', value: 'typed IPC' },
      { label: 'services', value: 'agents + scheduler' },
      { label: 'risk', value: 'RI workflows' },
      { label: 'guardrail', value: 'sanitized demo' },
    ],
    bars: [
      { label: 'prototype concreteness', value: 'high', width: 88, tone: 'green' },
      { label: 'enterprise hardening', value: 'next gate', width: 58, tone: 'amb' },
