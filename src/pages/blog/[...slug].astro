---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const pub = post.data.pubDate.toISOString().slice(0, 10);
const updated = post.data.updatedDate?.toISOString().slice(0, 10);
const wordCount = post.body ? post.body.split(/\s+/).filter(Boolean).length : 0;
const readMins = Math.max(1, Math.round(wordCount / 220));

type Metric = { label: string; value: string; sub: string; tone?: 'amb' | 'teal' | 'green' | 'red' | 'rose' };
type Node = { label: string; value: string };
type Bar = { label: string; value: string; width: number; tone?: 'amb' | 'teal' | 'green' | 'red' };
type Visual = {
  eyebrow: string;
  heroTitle: string;
  kicker: string;
  status: string;
  statusTone: 'amb' | 'teal' | 'green' | 'red';
  metrics: Metric[];
  nodes: Node[];
  bars: Bar[];
  hookLabel: string;
  hook: string;
};

const visuals: Record<string, Visual> = {
  'fenixfire-careful-trading-robot': {
    eyebrow: 'kevinmjones / family guide / fenixfire',
    heroTitle: 'FenixFire: a careful <em>paper-trading</em> robot',
    kicker: 'A plain-English explanation of a stock-trading robot where the clever part suggests and a strict rulebook controls every order.',
    status: 'paper only',
    statusTone: 'green',
    metrics: [
      { label: 'mode', value: 'paper', sub: 'real money switched off', tone: 'green' },
      { label: 'risk checks', value: '20', sub: 'one failed check means no', tone: 'amb' },
      { label: 'holding time', value: '0 nights', sub: 'flat before market close', tone: 'teal' },
      { label: 'sample', value: '24', sub: 'practice trades, not proof', tone: 'rose' },
