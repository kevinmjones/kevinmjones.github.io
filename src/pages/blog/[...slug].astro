      { label: 'pricing basis', value: 'VWAP', sub: 'walks the book by notional', tone: 'teal' },
      { label: 'presets', value: '$1k–$50k', sub: 'notional-aware ranking', tone: 'amb' },
      { label: 'runtime', value: 'browser', sub: 'TypeScript + Vite + fetch', tone: 'rose' },
    ],
    nodes: [
      { label: 'public books', value: 'venue REST APIs' },
      { label: 'adapters', value: 'canonical OrderBook' },
      { label: 'math', value: 'VWAP + taker fees' },
      { label: 'ranker', value: 'net bps table' },
      { label: 'guardrail', value: 'no execution' },
    ],
    bars: [
      { label: 'security surface', value: 'small', width: 28, tone: 'green' },
      { label: 'venue adapter pain', value: 'high', width: 78, tone: 'amb' },
      { label: 'execution risk', value: 'none by design', width: 8, tone: 'green' },
