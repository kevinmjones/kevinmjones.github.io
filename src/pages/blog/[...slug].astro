    nodes: [
      { label: 'data', value: 'market + history' },
      { label: 'analyst', value: 'suggests' },
      { label: 'risk boss', value: 'vetoes' },
      { label: 'clerk', value: 'bracket orders' },
      { label: 'mode', value: 'practice broker' },
