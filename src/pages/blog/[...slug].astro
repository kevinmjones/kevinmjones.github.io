    kicker: 'A closed Wi‑Fi printer, a proprietary UDP protocol, and a parametric PETG drip spout.',
    status: 'hardware live',
    statusTone: 'teal',
    metrics: [
      { label: 'wire protocol', value: 'UDP/3000', sub: 'M-code request/reply', tone: 'teal' },
      { label: 'upload unit', value: '1280B', sub: 'chunked + ACK + retry', tone: 'amb' },
      { label: 'artifact', value: 'qidi-send', sub: 'Linux CLI around QIDI format', tone: 'green' },
      { label: 'watering run', value: '5–8d', sub: '20 oz bottle drip spout', tone: 'rose' },
    ],
    nodes: [
      { label: 'probe', value: 'M4001 handshake' },
      { label: 'compress', value: 'Wine + VC_compress' },
      { label: 'upload', value: 'chunked UDP' },
      { label: 'print', value: 'PETG spout' },
      { label: 'use', value: 'slow watering' },
    ],
    bars: [
      { label: 'stock Linux support', value: 'none', width: 8, tone: 'red' },
      { label: 'protocol mapped', value: 'enough', width: 78, tone: 'teal' },
      { label: 'plant survival', value: 'solved', width: 86, tone: 'green' },
    ],
    hookLabel: 'field lesson',
    hook: 'The protocol was less mysterious than the workflow around it: reuse one UDP socket, drain stale packets, and print the smallest verifying geometry first.',
  },
};

const visual = visuals[post.id] ?? {
  eyebrow: `kevinmjones / field note / ${post.data.tags[0] ?? 'blog'}`,
  heroTitle: post.data.title,
  kicker: post.data.description,
  status: 'field note',
  statusTone: 'amb',
  metrics: [
    { label: 'published', value: pub, sub: 'field note date', tone: 'amb' },
    { label: 'reading time', value: `${readMins}m`, sub: `${wordCount} words`, tone: 'teal' },
    { label: 'tags', value: `${post.data.tags.length}`, sub: post.data.tags.join(' · '), tone: 'green' },
    { label: 'format', value: 'report', sub: 'visual briefing + prose', tone: 'rose' },
  ],
  nodes: [
    { label: 'input', value: 'problem' },
    { label: 'system', value: 'build' },
    { label: 'artifact', value: 'result' },
  ],
  bars: [
    { label: 'prose', value: `${wordCount} words`, width: 70, tone: 'amb' },
    { label: 'visual layer', value: 'enabled', width: 90, tone: 'green' },
  ],
  hookLabel: 'note',
  hook: post.data.description,
} satisfies Visual;

const postUrl = new URL(`/blog/${post.id}/`, Astro.site ?? 'https://kevinmjones.github.io').toString();
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.pubDate.toISOString(),
    dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
    url: postUrl,
    mainEntityOfPage: postUrl,
    keywords: post.data.tags,
    wordCount,
    timeRequired: `PT${readMins}M`,
    author: { '@type': 'Person', name: 'Kevin Jones', url: 'https://github.com/kevinmjones' },
    publisher: { '@type': 'Person', name: 'Kevin Jones', url: 'https://kevinmjones.github.io' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://kevinmjones.github.io/' },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://kevinmjones.github.io/blog/' },
      { '@type': 'ListItem', position: 3, name: post.data.title, item: postUrl },
    ],
  },
];
---
<Layout title={post.data.title} description={post.data.description} ogType="article" schema={schema}>
  <article class="blog-article">
    <section class="report-masthead">
      <div>
        <div class="eyebrow">{visual.eyebrow}</div>
        <h1><Fragment set:html={visual.heroTitle} /></h1>
        <p class="mast-sub">{visual.kicker}</p>
      </div>
      <div class="mast-meta">
        published <b>{pub}</b><br />
        {updated && <>updated <b>{updated}</b><br /></>}
        read <b>{readMins} min</b><br />
        <span class={`clock ${visual.statusTone}`}>{visual.status}</span>
      </div>
    </section>

    <div class="tape">
      <div class="tape-track">
        <span><span class="lbl">slug</span> <span class="v amb">{post.id}</span></span>
        <span><span class="lbl">date</span> <span class="v">{pub}</span></span>
        <span><span class="lbl">tags</span> <span class="v teal">{post.data.tags.join(' · ')}</span></span>
        <span><span class="lbl">format</span> <span class="v green">visual field report</span></span>
      </div>
    </div>

    <section class="article-shell">
      <div class="section-head">
        <div class="sec-n">00</div>
        <div class="sec-title">Visual briefing <em>— before the prose</em></div>
        <div class="sec-meta">generated from post facts</div>
      </div>

      <div class="gauge-grid">
        {visual.metrics.map((metric) => (
          <div class={`card ${metric.tone ?? 'amb'}`}>
            <div class="card-label">{metric.label}</div>
            <div class={`card-value ${metric.tone ?? 'amb'}`}>{metric.value}</div>
            <div class="card-sub"><span class={`dot ${metric.tone ?? 'amb'}`}></span>{metric.sub}</div>
          </div>
        ))}
      </div>

      <div class="grid-2-1">
        <div>
          <div class="card-title">system map <span class="badge teal">flow</span></div>
          <div class="system-map">
            {visual.nodes.map((node, index) => (
              <>
                <div class="map-node">
                  <div class="node-label">{node.label}</div>
                  <div class="node-value">{node.value}</div>
                </div>
                {index < visual.nodes.length - 1 && <div class="map-arrow">→</div>}
              </>
            ))}
          </div>
        </div>
        <div class="panel" style="padding:1rem">
          <div class="card-title">signal bars <span class={`badge ${visual.statusTone}`}>{visual.status}</span></div>
          <div class="mini-bars">
            {visual.bars.map((bar) => (
              <div class="mini-bar">
                <span>{bar.label}</span>
                <span class="bar-track"><span class={`bar-fill ${bar.tone ?? 'amb'}`} style={`--w:${bar.width}%`}></span></span>
                <strong>{bar.value}</strong>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="honesty-hook" style="margin-top:1rem">
        <div class="hook-label">{visual.hookLabel}</div>
        <p>{visual.hook}</p>
      </div>

      <div class="article-prose">
        <Content />
      </div>
    </section>
  </article>

  <p class="backlink"><a href="/blog">← all posts</a></p>
</Layout>
