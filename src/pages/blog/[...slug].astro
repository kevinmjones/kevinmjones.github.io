    bars: [
      { label: 'real money exposure', value: 'off', width: 6, tone: 'green' },
      { label: 'automation', value: 'guarded', width: 72, tone: 'teal' },
      { label: 'sample-size proof', value: 'not yet', width: 18, tone: 'red' },
