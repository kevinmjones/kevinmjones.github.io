    heroTitle: 'What Kevin’s <em>weather computer</em> actually does',
    kicker: 'A jargon-free guide to forecasting LAX temperature buckets, comparing them to Kalshi prices, and staying paper-only.',
    status: 'paper only',
    statusTone: 'green',
    metrics: [
      { label: 'market', value: 'KLAX', sub: 'daily LAX high temperature', tone: 'amb' },
      { label: 'question', value: 'buckets', sub: 'odds for every range', tone: 'teal' },
      { label: 'key variable', value: 'fog', sub: 'marine layer drives misses', tone: 'rose' },
      { label: 'execution', value: 'paper', sub: 'real-money mode absent', tone: 'green' },
    ],
    nodes: [
      { label: 'weather', value: 'airport readings' },
      { label: 'forecast', value: 'bucket odds' },
      { label: 'market', value: 'Kalshi prices' },
      { label: 'decision', value: 'paper bet or pass' },
      { label: 'learning', value: 'nightly report' },
    ],
    bars: [
      { label: 'fog importance', value: 'high', width: 86, tone: 'amb' },
      { label: 'real money exposure', value: 'none', width: 6, tone: 'green' },
      { label: 'learning loop', value: 'active', width: 78, tone: 'teal' },
