---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const latest = posts[0];
const rest = posts.slice(1);
const allTags = [...new Set(posts.flatMap((post) => post.data.tags))];
const latestDate = latest?.data.pubDate.toISOString().slice(0, 10) ?? '—';

const visualFor = (id: string, tags: string[] = []) => {
  if (id.includes('fenixfire')) {
    return [
      ['mode', 'paper-only', 'green'],
      ['risk', '20 checks', 'amb'],
      ['holding', '0 nights', 'teal'],
    ];
  }
  if (id.includes('weather-computer-family-guide')) {
    return [
      ['mode', 'paper-only', 'green'],
      ['market', 'KLAX', 'amb'],
      ['driver', 'fog', 'teal'],
    ];
  }
  if (id.includes('klax26')) {
    return [
      ['settlement', 'NWS CLI LAX', 'amb'],
      ['audit', '260/261', 'green'],
      ['brier', '0.7286', 'teal'],
    ];
  }
  if (id.includes('xrp')) {
    return [
      ['mode', 'read-only', 'green'],
      ['calc', 'VWAP', 'teal'],
      ['scope', 'XRP/USD', 'amb'],
    ];
  }
  if (id.includes('qidi')) {
    return [
      ['protocol', 'UDP/3000', 'teal'],
      ['artifact', 'qidi-send', 'amb'],
      ['print', 'PETG', 'green'],
    ];
  }
  return [
    ['format', 'field note', 'green'],
    ['tags', `${tags.length}`, 'teal'],
    ['brief', 'visual', 'amb'],
  ];
};
---
<Layout title="blog" description="Field notes by Kevin Jones">
  <div class="blog-index">
    <section class="report-masthead">
      <div>
        <div class="eyebrow">kevinmjones / blog / field notes</div>
        <h1>Build notes with <em>receipts</em>, not launch posts.</h1>
        <p class="mast-sub">
          Systems, trading infrastructure, reverse-engineering, and agent workflows —
          written as operational reports with the caveats left in.
        </p>
      </div>
      <div class="mast-meta">
        report date <b>{latestDate}</b><br />
        posts <b>{posts.length}</b><br />
        tags <b>{allTags.length}</b><br />
        <span class="clock">static / github pages</span>
      </div>
    </section>

    <div class="tape">
      <div class="tape-track">
        <span><span class="lbl">latest</span> <span class="v amb">{latest?.data.title ?? '—'}</span></span>
        <span><span class="lbl">post count</span> <span class="v">{posts.length}</span></span>
        <span><span class="lbl">primary tags</span> <span class="v teal">{allTags.slice(0, 6).join(' · ')}</span></span>
        <span><span class="lbl">format</span> <span class="v green">field report</span></span>
      </div>
    </div>

    {latest && (
      <a class="report-card featured" href={`/blog/${latest.id}`}>
        <div>
          <div class="meta-row">latest field note · {latest.data.pubDate.toISOString().slice(0, 10)}</div>
          <h2>{latest.data.title}</h2>
          <p>{latest.data.description}</p>
          <div>
            {latest.data.tags.map((t) => <span class="tag">{t}</span>)}
          </div>
        </div>
        <div class="card-visual">
          <div class="card-title">briefing strip <span class="badge amb">open report</span></div>
          <div class="mini-bars">
            {visualFor(latest.id, latest.data.tags).map(([label, value, tone], i) => (
              <div class="mini-bar">
                <span>{label}</span>
                <span class="bar-track"><span class={`bar-fill ${tone}`} style={`--w:${88 - i * 18}%`}></span></span>
                <strong>{value}</strong>
              </div>
            ))}
          </div>
        </div>
      </a>
    )}

    {rest.length > 0 && (
      <>
        <div class="section-head">
          <div class="sec-n">01</div>
          <div class="sec-title">Archive <em>— prior field reports</em></div>
          <div class="sec-meta">newest first</div>
        </div>
        <div class="post-grid">
          {rest.map((post) => (
            <a class="report-card" href={`/blog/${post.id}`}>
              <div class="meta-row">{post.data.pubDate.toISOString().slice(0, 10)}</div>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <div class="mini-bars">
                {visualFor(post.id, post.data.tags).map(([label, value, tone], i) => (
                  <div class="mini-bar">
                    <span>{label}</span>
                    <span class="bar-track"><span class={`bar-fill ${tone}`} style={`--w:${82 - i * 20}%`}></span></span>
                    <strong>{value}</strong>
                  </div>
                ))}
              </div>
            </a>
          ))}
        </div>
      </>
    )}
  </div>
</Layout>
