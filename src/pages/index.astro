---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recent = posts.slice(0, 4);

const featuredProjects = [
  {
    name: 'FenixFire',
    label: 'Trading system',
    description: 'A paper-only stock-trading robot with separate analyst, risk, and execution roles.',
    href: '/blog/fenixfire-careful-trading-robot/',
  },
  {
    name: 'KLAX26',
    label: 'Forecasting',
    description: 'A weather-market research system built around provenance, calibrated forecasts, and careful execution.',
    href: '/blog/klax26-weather-computer-family-guide/',
  },
  {
    name: 'qidi-research',
    label: 'Reverse engineering',
    description: 'A Unix toolchain for a 3D printer built by mapping its proprietary UDP protocol.',
    href: 'https://github.com/kevinmjones/qidi-research',
  },
  {
    name: 'TARS',
    label: 'Hardware',
    description: 'Servo control, hardware mocks, and real-world drivers for a working robot replica.',
    href: '/projects',
  },
];
---
<Layout title="Kevin Jones">
  <div class="home-page">
    <section class="home-hero-panel reveal" aria-labelledby="home-title">
      <div class="home-contents">
        <div class="micro-label">Kevin Jones · independent builder</div>
        <nav aria-label="Home contents">
          <a href="#work"><span>01</span> Work</a>
          <a href="#notes"><span>02</span> Field notes</a>
          <a href="/about"><span>03</span> About</a>
        </nav>
      </div>
      <div class="home-intro">
        <div class="micro-label blue">Systems · agents · markets · hardware</div>
        <h1 id="home-title">I build systems that <span>earn</span> their autonomy.</h1>
        <p>
          Agent tooling, trading infrastructure, reverse-engineered protocols, and
          small sharp tools. The clever part suggests; the rulebook approves.
        </p>
        <div class="hero-links">
          <a class="primary" href="#work">Explore the work →</a>
          <a href="/about">About Kevin</a>
        </div>
      </div>
      <div class="hero-foot">
        <span>Building in the open</span>
        <span>Python · TypeScript · hardware</span>
        <span>Based in the United States</span>
      </div>
    </section>

    <section class="home-index reveal d1" aria-label="At a glance">
      <div class="index-title"><span>00</span><h2>At a glance</h2></div>
      <div class="signal-grid">
        <a href="/projects"><span class="signal-arrow">→</span><b>Current work</b><em>agents, markets, protocols</em></a>
        <a href="/blog"><span class="signal-arrow">→</span><b>Field notes</b><em>{posts.length} reports with the caveats left in</em></a>
        <a href="/about"><span class="signal-arrow">→</span><b>Operating mode</b><em>paper-first, evidence-led</em></a>
      </div>
    </section>

    <section class="home-index reveal d2" id="work">
      <div class="index-title">
        <span>01</span><h2>Selected work</h2><a href="/projects">All projects →</a>
      </div>
      <div class="editorial-list project-list">
        {featuredProjects.map((project, index) => (
          <a href={project.href}>
            <span class="row-id">P—{String(index + 1).padStart(2, '0')}</span>
            <span class="row-copy"><small>{project.label}</small><strong>{project.name}</strong><em>{project.description}</em></span>
            <span class="row-arrow">↗</span>
          </a>
        ))}
      </div>
    </section>

    {recent.length > 0 && (
      <section class="home-index reveal d3" id="notes">
        <div class="index-title">
          <span>02</span><h2>Latest field notes</h2><a href="/blog">Full archive →</a>
        </div>
        <div class="editorial-list note-list">
          {recent.map((post, index) => (
            <a href={`/blog/${post.id}`}>
              <span class="row-id">N—{String(index + 1).padStart(2, '0')}</span>
              <span class="row-copy"><small>{post.data.pubDate.toISOString().slice(0, 10)}</small><strong>{post.data.title}</strong><em>{post.data.description}</em></span>
              <span class="row-arrow">→</span>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</Layout>
