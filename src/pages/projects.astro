---
import Layout from '../layouts/Layout.astro';

interface Project {
  name: string;
  pitch: string;
  stack: string;
  status: 'active' | 'maintained' | 'archived';
  accent?: string;
  link?: string;
}

const tier1: Project[] = [
  {
    name: 'FenixFire',
    pitch:
      'Paper-only stock-trading robot with separated analyst, risk boss, and execution clerk roles. The smart layer suggests; the rulebook owns approval.',
    stack: 'Python · Alpaca paper trading · risk engine · dashboard',
    status: 'active',
    accent: 'var(--red)',
    link: '/blog/fenixfire-careful-trading-robot/',
  },
  {
    name: 'KLAX26',
    pitch:
      'Weather-market research system for Kalshi LAX high-temperature buckets, built around settlement provenance, calibrated forecasts, and paper-only execution.',
    stack: 'Python · Kalshi · weather data · forecasting',
    status: 'active',
    accent: 'var(--teal)',
    link: '/blog/klax26-weather-computer-family-guide/',
  },
  {
    name: 'qidi-research',
    pitch:
      'Reverse-engineered the Qidi X-CF Pro 3D printer\'s proprietary UDP/3000 wire protocol to drive it from a Unix CLI — and wired it into a parametric OpenSCAD-to-printer pipeline.',
    stack: 'Python · OpenSCAD · PrusaSlicer · Wine',
    status: 'active',
    accent: 'var(--green)',
    link: 'https://github.com/kevinmjones/qidi-research',
  },
  {
    name: 'polykali',
    pitch:
      'Algorithmic Polymarket trading bot with a custom risk daemon, delegation logic, and a quantitative research harness for tuning live strategies.',
    stack: 'Python · Polymarket on-chain · async pipelines',
    status: 'active',
    accent: 'var(--rose)',
  },
];

const tier2: Project[] = [
  {
    name: 'alpacaman',
    pitch:
      'Multi-agent day-trading system: a LangGraph supervisor coordinates research, risk, execution, and reporting agents against the Alpaca paper-trading API.',
    stack: 'Python · LangGraph · Alpaca · vectorbt · Docker',
    status: 'active',
  },
  {
    name: 'TARS',
    pitch:
      'Servo controller and hardware-mock layer for a TARS robot replica. Runs without hardware for development; ships PCA9685 / MG996R drivers for real builds.',
    stack: 'Python · I²C · servo control',
    status: 'maintained',
  },
  {
    name: 'sesame',
    pitch:
      'Real-time conversational voice agent: CSM-1B TTS + faster-whisper STT + pluggable LLM, served over FastAPI / WebSockets.',
    stack: 'Python · FastAPI · WebSockets · faster-whisper · CSM',
    status: 'maintained',
  },
  {
    name: 'politics',
    pitch:
      'Kalshi prediction-market bot using Octagon Deep Research + an LLM ensemble for structured event bets.',
    stack: 'Python · Kalshi API · async data ingestion',
    status: 'active',
  },
  {
    name: 'llmz',
    pitch:
      'A visual gallery of identical one-shot HTML generations across ~17 frontier LLMs. Useful for at-a-glance comparison of model aesthetics.',
    stack: 'static site · multi-provider API client',
    status: 'maintained',
  },
];

const badgeTone = (s: Project['status']) =>
  s === 'active' ? 'green' : s === 'maintained' ? 'teal' : '';
---
<Layout title="projects" description="Projects by Kevin Jones">
  <section class="report-masthead reveal">
    <div>
      <div class="eyebrow">kevinmjones / projects / build log</div>
      <h1>Things that resisted <em>being automated</em>.</h1>
      <p class="mast-sub">
        Mostly Python, mostly involving LLMs, agents, or a protocol that wasn't
        supposed to be driven from a Unix shell. Each headliner has a field note
        documenting how it actually went.
      </p>
    </div>
    <div class="mast-meta">
      headliners <b>{tier1.length}</b><br />
      also active <b>{tier2.length}</b><br />
      default mode <b>paper / read-only</b><br />
      <span class="clock">build log</span>
    </div>
  </section>

  <div class="reveal d1">
    <div class="section-head">
      <div class="sec-n">01</div>
      <div class="sec-title">Headliners <em>— the systems with receipts</em></div>
      <div class="sec-meta">{tier1.length} projects</div>
    </div>
    <div class="project-grid">
      {tier1.map((p, i) => {
        const inner = (
          <>
            <div class="proj-top">
              <h3>{p.name}</h3>
              <span class={`badge ${badgeTone(p.status)}`}>{p.status}</span>
            </div>
            <p>{p.pitch}</p>
            <div class="proj-stack">{p.stack}</div>
            <div class="proj-index">{String(i + 1).padStart(2, '0')}</div>
          </>
        );
        return p.link
          ? <a class="project-card" href={p.link} style={`--accent:${p.accent ?? 'var(--amber)'}`}>{inner}</a>
          : <div class="project-card" style={`--accent:${p.accent ?? 'var(--amber)'}`}>{inner}</div>;
      })}
    </div>
  </div>

  <div class="reveal d2">
    <div class="section-head">
      <div class="sec-n">02</div>
      <div class="sec-title">Also working on <em>— the supporting cast</em></div>
      <div class="sec-meta">{tier2.length} projects</div>
    </div>
    <div class="project-grid">
      {tier2.map((p, i) => (
        <div class="project-card" style="--accent:var(--rule)">
          <div class="proj-top">
            <h3>{p.name}</h3>
            <span class={`badge ${badgeTone(p.status)}`}>{p.status}</span>
          </div>
          <p>{p.pitch}</p>
          <div class="proj-stack">{p.stack}</div>
          <div class="proj-index">{String(i + 5).padStart(2, '0')}</div>
        </div>
      ))}
    </div>
  </div>
</Layout>
